---
import ToolPage from '../../layouts/ToolPage.astro';
import PSBTEditor from '../../components/tools/PSBTEditor.astro';
import { TOOLS, TOOL_LABELS } from '../../data/tools-meta';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ko' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;
const tool = TOOLS.find(t => t.slug === 'psbt-editor')!;
---

<ToolPage
  title={tool.title[lang!] || tool.title.en}
  description={tool.description[lang!] || tool.description.en}
  lang={lang!}
  canonicalPath={`/${lang}/psbt-editor/`}
  keywords={tool.keywords}
  toolName={TOOL_LABELS['psbt-editor'][lang!] || TOOL_LABELS['psbt-editor'].en}
>
  <PSBTEditor />
</ToolPage>
