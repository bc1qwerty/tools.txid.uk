---
import ToolPage from '../../layouts/ToolPage.astro';
import TxBroadcast from '../../components/tools/TxBroadcast.astro';
import { TOOLS, TOOL_LABELS } from '../../data/tools-meta';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ko' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;
const tool = TOOLS.find(t => t.slug === 'tx-broadcast')!;
---

<ToolPage
  title={tool.title[lang!] || tool.title.en}
  description={tool.description[lang!] || tool.description.en}
  lang={lang!}
  canonicalPath={`/${lang}/tx-broadcast/`}
  keywords={tool.keywords}
  toolName={TOOL_LABELS['tx-broadcast'][lang!] || TOOL_LABELS['tx-broadcast'].en}
>
  <TxBroadcast />
</ToolPage>
