---
import ToolPage from '../../layouts/ToolPage.astro';
import OpCodeRef from '../../components/tools/OpCodeRef.astro';
import { TOOLS, TOOL_LABELS } from '../../data/tools-meta';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ko' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;
const tool = TOOLS.find(t => t.slug === 'opcode-ref')!;
---

<ToolPage
  title={tool.title[lang!] || tool.title.en}
  description={tool.description[lang!] || tool.description.en}
  lang={lang!}
  canonicalPath={`/${lang}/opcode-ref/`}
  keywords={tool.keywords}
  toolName={TOOL_LABELS['opcode-ref'][lang!] || TOOL_LABELS['opcode-ref'].en}
>
  <OpCodeRef />
</ToolPage>
