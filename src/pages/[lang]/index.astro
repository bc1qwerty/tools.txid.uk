---
import Base from '../../layouts/Base.astro';
import Header from '@txid/ui/components/Header.astro';
import Footer from '@txid/ui/components/Footer.astro';
import PageScript from '../../components/PageScript.astro';
import '../../styles/global.css';
import { TOOLS, TOOL_LABELS, TOOL_SHORT_DESC } from '../../data/tools-meta';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ko' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;

const titles: Record<string, string> = {
  ko: 'Bitcoin Developer Tools — 주소 검증, 스크립트 디코더, LN Invoice 디코더 | txid.uk',
  en: 'Bitcoin Developer Tools — Address Validator, Script Decoder, LN Invoice Decoder | txid.uk',
  ja: 'Bitcoin開発ツール — アドレス検証、スクリプトデコーダ、LNインボイスデコーダ | txid.uk',
};

const descriptions: Record<string, string> = {
  ko: '비트코인 개발자 도구 모음. 주소 검증, 스크립트 디코더, Bech32/Base58 디코더, BTC 단위 변환, OP 코드 사전, Lightning Invoice(BOLT11) 디코더.',
  en: 'Bitcoin developer toolkit. Address validator, script decoder, Bech32/Base58 decoder, BTC unit converter, OP code reference, Lightning Invoice (BOLT11) decoder.',
  ja: 'ビットコイン開発者ツール集。アドレス検証、スクリプトデコーダ、Bech32/Base58デコーダ、BTC単位変換、OPコード辞典、Lightningインボイス(BOLT11)デコーダ。',
};

const i18n: Record<string, Record<string, string>> = {
  learnMore: { ko: '더 알아보기', en: 'Learn more', ja: 'もっと学ぶ' },
  walletChip: { ko: '지갑 주소란', en: 'Wallet Addresses', ja: 'ウォレットアドレス' },
  txChip: { ko: '트랜잭션 읽는 법', en: 'Reading Transactions', ja: 'トランザクションの読み方' },
  heroSub: { ko: '개발자·파워유저를 위한 비트코인 도구 모음', en: 'Bitcoin tools for developers & power users', ja: '開発者向けビットコインツール集' },
};

const tx = (key: string) => i18n[key]?.[lang!] || i18n[key]?.en || key;
const learnLangPrefix = lang === 'en' ? 'en' : lang === 'ja' ? 'ja' : 'ko';
---

<Base
  title={titles[lang!] || titles.en}
  description={descriptions[lang!] || descriptions.en}
  lang={lang!}
  canonicalPath={`/${lang}/`}
>
  <Header sub="Tools" />

  <div class="learn-links" id="learn-links">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-noshrink" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    <span class="learn-label">{tx('learnMore')}</span>
    <a class="learn-chip" data-slug="bitcoin-wallet-address" href={`https://learn.txid.uk/${learnLangPrefix}/blog/bitcoin-wallet-address/`} target="_blank" rel="noopener">{tx('walletChip')}</a>
    <a class="learn-chip" data-slug="how-to-read-bitcoin-transaction" href={`https://learn.txid.uk/${learnLangPrefix}/blog/how-to-read-bitcoin-transaction/`} target="_blank" rel="noopener">{tx('txChip')}</a>
  </div>

  <!-- Shared utilities for setLang/t functions -->
  <script is:inline src="/tools-shared.js"></script>

  <main id="main">
    <div class="hero">
      <h1>Bitcoin <span class="accent">Tools</span></h1>
      <p class="hero-sub">{tx('heroSub')}</p>
    </div>
    <div class="tools-directory">
      {TOOLS.map((tool) => (
        <a href={`/${lang}/${tool.slug}/`} class="tool-dir-card">
          <div class="tool-dir-icon">
            <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={tool.icon} />
            </svg>
          </div>
          <div class="tool-dir-info">
            <h2 class="tool-dir-name">{TOOL_LABELS[tool.slug][lang!] || TOOL_LABELS[tool.slug].en}</h2>
            <p class="tool-dir-desc">{TOOL_SHORT_DESC[tool.slug][lang!] || TOOL_SHORT_DESC[tool.slug].en}</p>
          </div>
          <svg class="tool-dir-arrow" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      ))}
    </div>
  </main>

  <Footer />
  <PageScript lang={lang!} />
</Base>

<style>
  .tools-directory {
    max-width: var(--max-w, 1200px);
    margin: 0 auto;
    padding: 0 20px 60px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 12px;
  }
  .tool-dir-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius, 8px);
    text-decoration: none;
    color: inherit;
    transition: border-color .2s, transform .15s;
  }
  .tool-dir-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .tool-dir-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(247, 147, 26, 0.08);
    border-radius: 8px;
  }
  .tool-dir-icon .tool-icon {
    width: 20px;
    height: 20px;
    color: var(--accent-text);
  }
  .tool-dir-info {
    flex: 1;
    min-width: 0;
  }
  .tool-dir-name {
    font-size: .88rem;
    font-weight: 600;
    font-family: var(--font-ko);
    color: var(--text1);
    margin: 0 0 4px;
  }
  .tool-dir-desc {
    font-size: .75rem;
    font-family: var(--font-ko);
    color: var(--text3);
    margin: 0;
    line-height: 1.4;
  }
  .tool-dir-arrow {
    flex-shrink: 0;
    color: var(--text3);
    transition: color .2s, transform .2s;
  }
  .tool-dir-card:hover .tool-dir-arrow {
    color: var(--accent);
    transform: translateX(2px);
  }
  @media (max-width: 600px) {
    .tools-directory {
      grid-template-columns: 1fr;
    }
  }
</style>
