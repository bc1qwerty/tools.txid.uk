---
import Base from '../../layouts/Base.astro';
import Header from '@txid/ui/components/Header.astro';
import Footer from '@txid/ui/components/Footer.astro';
import '../../styles/global.css';

import AddressValidator from '../../components/tools/AddressValidator.astro';
import ScriptDecoder from '../../components/tools/ScriptDecoder.astro';
import UnitConverter from '../../components/tools/UnitConverter.astro';
import Bech32Decoder from '../../components/tools/Bech32Decoder.astro';
import TxBroadcast from '../../components/tools/TxBroadcast.astro';
import OpCodeRef from '../../components/tools/OpCodeRef.astro';
import ScriptIDE from '../../components/tools/ScriptIDE.astro';
import PSBTEditor from '../../components/tools/PSBTEditor.astro';
import LightningDecoder from '../../components/tools/LightningDecoder.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ko' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;

const titles: Record<string, string> = {
  ko: 'Bitcoin Developer Tools — 주소 검증, 스크립트 디코더, LN Invoice 디코더 | txid.uk',
  en: 'Bitcoin Developer Tools — Address Validator, Script Decoder, LN Invoice Decoder | txid.uk',
  ja: 'Bitcoin開発ツール — アドレス検証、スクリプトデコーダ、LNインボイスデコーダ | txid.uk',
};

const descriptions: Record<string, string> = {
  ko: '비트코인 개발자 도구 모음. 주소 검증, 스크립트 디코더, Bech32/Base58 디코더, BTC 단위 변환, OP 코드 사전, Lightning Invoice(BOLT11) 디코더.',
  en: 'Bitcoin developer toolkit. Address validator, script decoder, Bech32/Base58 decoder, BTC unit converter, OP code reference, Lightning Invoice (BOLT11) decoder.',
  ja: 'ビットコイン開発者ツール集。アドレス検証、スクリプトデコーダ、Bech32/Base58デコーダ、BTC単位変換、OPコード辞典、Lightningインボイス(BOLT11)デコーダ。',
};

const i18n: Record<string, Record<string, string>> = {
  learnMore: { ko: '더 알아보기', en: 'Learn more', ja: 'もっと学ぶ' },
  walletChip: { ko: '지갑 주소란', en: 'Wallet Addresses', ja: 'ウォレットアドレス' },
  txChip: { ko: '트랜잭션 읽는 법', en: 'Reading Transactions', ja: 'トランザクションの読み方' },
  heroSub: { ko: '개발자·파워유저를 위한 비트코인 도구 모음', en: 'Bitcoin tools for developers & power users', ja: '開発者向けビットコインツール集' },
};

const tx = (key: string) => i18n[key]?.[lang!] || i18n[key]?.en || key;
const learnLangPrefix = lang === 'en' ? 'en' : lang === 'ja' ? 'ja' : 'ko';
---

<Base
  title={titles[lang!] || titles.en}
  description={descriptions[lang!] || descriptions.en}
  lang={lang!}
>
  <Header sub="Tools" />

  <div class="learn-links" id="learn-links">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-noshrink" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    <span class="learn-label">{tx('learnMore')}</span>
    <a class="learn-chip" data-slug="bitcoin-wallet-address" href={`https://learn.txid.uk/${learnLangPrefix}/blog/bitcoin-wallet-address/`} target="_blank" rel="noopener">{tx('walletChip')}</a>
    <a class="learn-chip" data-slug="how-to-read-bitcoin-transaction" href={`https://learn.txid.uk/${learnLangPrefix}/blog/how-to-read-bitcoin-transaction/`} target="_blank" rel="noopener">{tx('txChip')}</a>
  </div>

  <!-- Shared utilities must load before component scripts -->
  <script is:inline src="/tools-shared.js"></script>

  <main id="main">
    <div class="hero">
      <h1>Bitcoin <span class="accent">Tools</span></h1>
      <p class="hero-sub">{tx('heroSub')}</p>
    </div>
    <div class="tools-grid">

      <AddressValidator />
      <ScriptDecoder />
      <UnitConverter />
      <Bech32Decoder />
      <TxBroadcast />
      <OpCodeRef />
      <ScriptIDE />
      <PSBTEditor />
      <LightningDecoder />

    </div>
  </main>

  <Footer />

  <script define:vars={{ pageLang: lang }}>
    window.__pageLang = pageLang;
  </script>

  <!-- Theme & nav init (depends on shared utils above) -->
  <script is:inline>
    // ── Lang init with route-based navigation ──
    var pageLang = window.__pageLang || 'ko';
    var _origSetLang = setLang;
    setLang = function(l) {
      lang = l; localStorage.setItem('lang', lang);
      var target = '/' + lang + '/';
      if (window.location.pathname !== target) {
        window.location.href = target;
        return;
      }
      _origSetLang(l);
    };

    document.addEventListener('click',function(e){var m=document.getElementById('lang-menu');if(m&&!e.target.closest('.lang-dropdown')){m.classList.remove('open');document.getElementById('lang-btn')?.setAttribute('aria-expanded','false');}});

    // If stored lang differs from page lang, navigate
    if (lang !== pageLang && ['ko', 'en', 'ja'].indexOf(lang) >= 0) {
      window.location.href = '/' + lang + '/';
    }
    (function(){setLang(lang);})();

    // ── Theme ──
    (function() {
      var th = localStorage.getItem('theme') || 'dark';
      var isDark = th !== 'light';
      document.documentElement.setAttribute('data-theme', th);
      var btn = document.getElementById('theme-btn');
      if (btn) {
        btn.innerHTML=isDark?'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="4.22" y1="19.78" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.78" y2="4.22"/></svg>':'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
        btn.title=isDark?t('light_mode'):t('dark_mode');
      }
    })();
    function updateThemeBtn(){
      var btn=document.getElementById('theme-btn');if(!btn)return;
      var isDark=document.documentElement.getAttribute('data-theme')!=='light';
      btn.innerHTML=isDark?'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="4.22" y1="19.78" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.78" y2="4.22"/></svg>':'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
      btn.title=isDark?t('light_mode'):t('dark_mode');
    }
    function toggleTheme() {
      var h = document.documentElement;
      var next = h.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      h.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      updateThemeBtn();
    }

    // ── Nav event listeners ──
    document.getElementById('lang-btn')?.addEventListener('click', toggleLang);
    document.querySelectorAll('#lang-menu button').forEach(function(btn) {
      var l = btn.textContent === '한국어' ? 'ko' : btn.textContent === 'English' ? 'en' : 'ja';
      btn.addEventListener('click', function() { setLang(l); });
    });
    document.getElementById('theme-btn')?.addEventListener('click', toggleTheme);

    // ── Mobile hamburger menu ──
    document.getElementById('hamburger-btn')?.addEventListener('click', function() {
      var panel = document.getElementById('hamburger-panel');
      if (!panel) return;
      var open = panel.classList.toggle('open');
      this.setAttribute('aria-expanded', open);
      if (open) updateHamburger();
    });
    document.addEventListener('click', function(e) {
      var wrap = document.querySelector('.hamburger-wrap');
      var panel = document.getElementById('hamburger-panel');
      if (wrap && panel && !wrap.contains(e.target)) {
        panel.classList.remove('open');
        document.getElementById('hamburger-btn')?.setAttribute('aria-expanded', 'false');
      }
    });
    document.querySelectorAll('#hamburger-panel .settings-lang-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        setLang(btn.dataset.lang);
        document.getElementById('hamburger-panel')?.classList.remove('open');
        document.getElementById('hamburger-btn')?.setAttribute('aria-expanded', 'false');
      });
    });
    document.getElementById('hamburger-theme-btn')?.addEventListener('click', function() {
      toggleTheme();
      updateHamburger();
    });
    function updateHamburger() {
      var isDark = document.documentElement.getAttribute('data-theme') !== 'light';
      var icon = document.getElementById('hamburger-theme-icon');
      if (icon) icon.innerHTML = isDark
        ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="4.22" y1="19.78" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.78" y2="4.22"/></svg>'
        : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
      document.querySelectorAll('#hamburger-panel .settings-lang-btn').forEach(function(b) {
        b.classList.toggle('active', b.dataset.lang === lang);
      });
    }
  </script>
</Base>
