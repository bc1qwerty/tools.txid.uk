---
import ToolPage from '../../layouts/ToolPage.astro';
import AddressValidator from '../../components/tools/AddressValidator.astro';
import { TOOLS, TOOL_LABELS } from '../../data/tools-meta';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ko' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;
const tool = TOOLS.find(t => t.slug === 'address-validator')!;
---

<ToolPage
  title={tool.title[lang!] || tool.title.en}
  description={tool.description[lang!] || tool.description.en}
  lang={lang!}
  canonicalPath={`/${lang}/address-validator/`}
  keywords={tool.keywords}
  toolName={TOOL_LABELS['address-validator'][lang!] || TOOL_LABELS['address-validator'].en}
>
  <AddressValidator />
</ToolPage>
