---
import Base from '../layouts/Base.astro';
import Header from '@txid/ui/components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Base
  title="Bitcoin Developer Tools — Address Validator, Script Decoder, LN Invoice Decoder | txid.uk"
  description="비트코인 개발자 도구 모음. 주소 검증, 스크립트 디코더, Bech32/Base58 디코더, BTC 단위 변환, OP 코드 사전, Lightning Invoice(BOLT11) 디코더."
>
  <Header sub="Tools" />

  <div class="learn-links" id="learn-links">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-noshrink" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    <span class="learn-label" data-ko="더 알아보기" data-en="Learn more" data-ja="もっと学ぶ">더 알아보기</span>
    <a class="learn-chip" data-slug="bitcoin-wallet-address" data-ko="지갑 주소란" data-en="Wallet Addresses" data-ja="ウォレットアドレス" href="https://learn.txid.uk/ko/blog/bitcoin-wallet-address/" target="_blank" rel="noopener">지갑 주소란</a>
    <a class="learn-chip" data-slug="how-to-read-bitcoin-transaction" data-ko="트랜잭션 읽는 법" data-en="Reading Transactions" data-ja="トランザクションの読み方" href="https://learn.txid.uk/ko/blog/how-to-read-bitcoin-transaction/" target="_blank" rel="noopener">트랜잭션 읽는 법</a>
  </div>

  <main id="main">
    <div class="hero">
      <h1>Bitcoin <span class="accent">Tools</span></h1>
      <p class="hero-sub" data-ko="개발자·파워유저를 위한 비트코인 도구 모음" data-en="Bitcoin tools for developers &amp; power users" data-ja="開発者向けビットコインツール集">개발자·파워유저를 위한 비트코인 도구 모음</p>
    </div>
    <div class="tools-grid">

      <section class="tool-card" id="tool-address">
        <div class="tool-header">
          <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <h2 data-ko="주소 검증 · 분석" data-en="Address Validation &amp; Analysis" data-ja="アドレス検証・分析">주소 검증 · 분석</h2>
        </div>
        <div class="tool-body">
          <input id="addr-input" class="tool-input" placeholder="Bitcoin 주소 입력 (bc1, 1, 3...)" data-ko="Bitcoin 주소 입력 (bc1, 1, 3...)" data-en="Enter Bitcoin address (bc1, 1, 3...)" data-ja="Bitcoinアドレス入力 (bc1, 1, 3...)" aria-label="비트코인 주소 입력" spellcheck="false">
          <button class="tool-btn" id="btn-analyze-addr" data-ko="분석" data-en="Analyze" data-ja="分析">분석</button>
          <div id="addr-result" class="tool-result"></div>
        </div>
      </section>

      <section class="tool-card" id="tool-script">
        <div class="tool-header">
          <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          <h2 data-ko="스크립트 디코더" data-en="Script Decoder" data-ja="スクリプトデコーダー">스크립트 디코더</h2>
        </div>
        <div class="tool-body">
          <input id="script-input" class="tool-input" placeholder="scriptPubKey hex (예: 76a914...88ac)" data-ko="scriptPubKey hex (예: 76a914...88ac)" data-en="scriptPubKey hex (e.g. 76a914...88ac)" data-ja="scriptPubKey hex (例: 76a914...88ac)" aria-label="스크립트 hex 입력" spellcheck="false">
          <button class="tool-btn" id="btn-decode-script" data-ko="디코드" data-en="Decode" data-ja="デコード">디코드</button>
          <div id="script-result" class="tool-result"></div>
        </div>
      </section>

      <section class="tool-card" id="tool-unit">
        <div class="tool-header">
          <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <h2 data-ko="단위 변환기" data-en="Unit Converter" data-ja="単位変換器">단위 변환기</h2>
        </div>
        <div class="tool-body">
          <div class="conv-row"><label for="conv-btc">BTC</label><input id="conv-btc" class="tool-input sm" type="number" placeholder="0.0"></div>
          <div class="conv-row"><label for="conv-sat">Satoshi</label><input id="conv-sat" class="tool-input sm" type="number" placeholder="0"></div>
          <div class="conv-row"><label for="conv-mbtc">mBTC</label><input id="conv-mbtc" class="tool-input sm" type="number" placeholder="0.0"></div>
          <div class="conv-row"><label for="conv-bits">bits (μBTC)</label><input id="conv-bits" class="tool-input sm" type="number" placeholder="0.0"></div>
          <div class="conv-row"><label for="conv-krw" data-ko="KRW (원)" data-en="KRW (₩)" data-ja="KRW (₩)">KRW (원)</label><input id="conv-krw" class="tool-input sm" type="number" placeholder="0"></div>
          <div class="conv-row"><label for="conv-usd">USD ($)</label><input id="conv-usd" class="tool-input sm" type="number" placeholder="0"></div>
          <div class="conv-price-info" id="conv-price-info" data-ko="가격 로딩 중…" data-en="Loading price..." data-ja="価格読み込み中…">가격 로딩 중…</div>
        </div>
      </section>

      <section class="tool-card" id="tool-bech32">
        <div class="tool-header">
          <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          <h2 data-ko="Bech32 / Base58 디코더" data-en="Bech32 / Base58 Decoder" data-ja="Bech32 / Base58 デコーダー">Bech32 / Base58 디코더</h2>
        </div>
        <div class="tool-body">
          <input id="enc-input" class="tool-input" placeholder="주소 또는 hex 입력" data-ko="주소 또는 hex 입력" data-en="Enter address or hex" data-ja="アドレスまたはhex入力" aria-label="Bech32 또는 Base58 주소 입력" spellcheck="false">
          <div class="btn-row">
            <button class="tool-btn sm" id="btn-decode-bech32" data-ko="Bech32 디코드" data-en="Bech32 Decode" data-ja="Bech32 デコード">Bech32 디코드</button>
            <button class="tool-btn sm" id="btn-decode-base58" data-ko="Base58 디코드" data-en="Base58 Decode" data-ja="Base58 デコード">Base58 디코드</button>
          </div>
          <div id="enc-result" class="tool-result"></div>
        </div>
      </section>

      <section class="tool-card" id="tool-broadcast">
        <div class="tool-header">
          <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          <h2 data-ko="TX 브로드캐스트" data-en="TX Broadcast" data-ja="TXブロードキャスト">TX 브로드캐스트</h2>
        </div>
        <div class="tool-body">
          <textarea id="tx-hex" class="tool-input textarea" placeholder="서명된 트랜잭션 hex 붙여넣기" data-ko="서명된 트랜잭션 hex 붙여넣기" data-en="Paste signed transaction hex" data-ja="署名済みトランザクションhexを貼り付け" aria-label="서명된 TX hex" spellcheck="false" rows="4"></textarea>
          <button class="tool-btn danger" id="btn-broadcast-tx" data-ko="네트워크에 전송" data-en="Broadcast to Network" data-ja="ネットワークに送信">네트워크에 전송</button>
          <div id="broadcast-result" class="tool-result"></div>
        </div>
      </section>

      <section class="tool-card" id="tool-opcodes">
        <div class="tool-header">
          <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          <h2 data-ko="OP 코드 사전" data-en="OP Code Dictionary" data-ja="OPコード辞典">OP 코드 사전</h2>
        </div>
        <div class="tool-body">
          <input id="op-search" class="tool-input" placeholder="OP_RETURN, 0x6a, 106..." data-ko="OP_RETURN, 0x6a, 106..." data-en="OP_RETURN, 0x6a, 106..." data-ja="OP_RETURN, 0x6a, 106..." aria-label="OP 코드 검색">
          <div id="op-result" class="tool-result op-grid"></div>
        </div>
      </section>

      <section class="tool-card tool-card--wide" id="tool-script-ide">
        <div class="tool-header">
          <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          <h2 data-ko="Script IDE" data-en="Script IDE" data-ja="Script IDE">Script IDE</h2>
        </div>
        <div class="tool-body">
          <!-- Template selector -->
          <div class="ide-toolbar">
            <label class="ide-label" for="ide-template" data-ko="템플릿" data-en="Template" data-ja="テンプレート">템플릿</label>
            <select id="ide-template" class="ide-select">
              <option value="" data-ko="— 선택 —" data-en="— Select —" data-ja="— 選択 —">— 선택 —</option>
              <option value="p2pkh">P2PKH</option>
              <option value="p2sh">P2SH</option>
              <option value="multisig">Multisig (2-of-3)</option>
              <option value="timelock" data-ko="타임락" data-en="Time-locked" data-ja="タイムロック">타임락</option>
              <option value="opreturn">OP_RETURN</option>
              <option value="math" data-ko="산술 예제" data-en="Math Example" data-ja="算術の例">산술 예제</option>
            </select>
            <div class="ide-toolbar-right">
              <button class="tool-btn sm ide-btn" id="btn-ide-run" data-ko="실행" data-en="Run" data-ja="実行">실행</button>
              <button class="tool-btn sm ide-btn ide-btn-step" id="btn-ide-step" data-ko="스텝" data-en="Step" data-ja="ステップ">스텝</button>
              <button class="tool-btn sm ide-btn ide-btn-back" id="btn-ide-back" data-ko="뒤로" data-en="Back" data-ja="戻る">뒤로</button>
              <button class="tool-btn sm ide-btn ide-btn-reset" id="btn-ide-reset" data-ko="초기화" data-en="Reset" data-ja="リセット">초기화</button>
            </div>
          </div>

          <div class="ide-main">
            <!-- Editor pane -->
            <div class="ide-editor-pane">
              <div class="ide-editor-label" data-ko="스크립트 에디터" data-en="Script Editor" data-ja="スクリプトエディタ">스크립트 에디터</div>
              <div class="ide-editor-wrap" id="ide-editor-wrap">
                <div class="ide-line-numbers" id="ide-line-numbers" aria-hidden="true">1</div>
                <div class="ide-editor-container">
                  <pre class="ide-highlight" id="ide-highlight" aria-hidden="true"></pre>
                  <textarea id="ide-editor" class="ide-textarea" spellcheck="false" autocomplete="off" autocapitalize="off" rows="12"
                    placeholder="OP_DUP&#10;OP_HASH160&#10;&#60;pubkeyhash&#62;&#10;OP_EQUALVERIFY&#10;OP_CHECKSIG"
                    data-ko="OP_DUP&#10;OP_HASH160&#10;&#60;pubkeyhash&#62;&#10;OP_EQUALVERIFY&#10;OP_CHECKSIG"
                    data-en="OP_DUP&#10;OP_HASH160&#10;&#60;pubkeyhash&#62;&#10;OP_EQUALVERIFY&#10;OP_CHECKSIG"
                    data-ja="OP_DUP&#10;OP_HASH160&#10;&#60;pubkeyhash&#62;&#10;OP_EQUALVERIFY&#10;OP_CHECKSIG"
                    aria-label="Bitcoin Script editor"></textarea>
                  <div class="ide-autocomplete" id="ide-autocomplete" role="listbox" style="display:none;"></div>
                </div>
              </div>
            </div>

            <!-- Stack visualizer -->
            <div class="ide-stack-pane">
              <div class="ide-editor-label" data-ko="스택 시각화" data-en="Stack Visualizer" data-ja="スタック可視化">스택 시각화</div>
              <div class="ide-stack-info">
                <span class="ide-stack-step" id="ide-step-info" data-ko="대기 중" data-en="Waiting" data-ja="待機中">대기 중</span>
              </div>
              <div class="ide-stack-visual" id="ide-stack-visual">
                <div class="ide-stack-empty" data-ko="스택이 비어 있습니다" data-en="Stack is empty" data-ja="スタックが空です">스택이 비어 있습니다</div>
              </div>
              <div class="ide-result" id="ide-result"></div>
            </div>
          </div>

          <!-- OP code quick ref toggle -->
          <details class="ide-ref-details">
            <summary class="ide-ref-summary" data-ko="OP 코드 빠른 참조" data-en="OP Code Quick Reference" data-ja="OPコード クイックリファレンス">OP 코드 빠른 참조</summary>
            <div class="ide-ref-grid" id="ide-ref-grid"></div>
          </details>
        </div>
      </section>

      <section class="tool-card tool-card--wide" id="tool-psbt">
        <div class="tool-header">
          <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="15" x2="15" y2="15"/><line x1="9" y1="11" x2="15" y2="11"/></svg>
          <h2 data-ko="PSBT 에디터" data-en="PSBT Editor" data-ja="PSBTエディタ">PSBT 에디터</h2>
        </div>
        <div class="tool-body">
          <div class="psbt-input-row">
            <textarea id="psbt-input" class="tool-input textarea" rows="4" spellcheck="false"
              placeholder="Base64 또는 hex 형식의 PSBT 붙여넣기"
              data-ko="Base64 또는 hex 형식의 PSBT 붙여넣기"
              data-en="Paste PSBT in Base64 or hex format"
              data-ja="Base64またはhex形式のPSBTを貼り付け"
              aria-label="PSBT input"></textarea>
            <div class="btn-row">
              <button class="tool-btn" id="btn-psbt-decode" data-ko="디코드" data-en="Decode" data-ja="デコード">디코드</button>
              <button class="tool-btn sm" id="btn-psbt-example" data-ko="예제 PSBT 로드" data-en="Load Example PSBT" data-ja="サンプルPSBTを読込">예제 PSBT 로드</button>
            </div>
          </div>
          <div id="psbt-result" class="tool-result"></div>
        </div>
      </section>

      <section class="tool-card tool-card--wide" id="tool-bolt11">
        <div class="tool-header">
          <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          <h2 data-ko="LN Invoice 디코더" data-en="LN Invoice Decoder" data-ja="LNインボイスデコーダー">LN Invoice 디코더</h2>
        </div>
        <div class="tool-body">
          <textarea id="bolt11-input" class="tool-input textarea" rows="3" spellcheck="false"
            placeholder="BOLT11 인보이스 붙여넣기 (lnbc...)"
            data-ko="BOLT11 인보이스 붙여넣기 (lnbc...)"
            data-en="Paste BOLT11 invoice (lnbc...)"
            data-ja="BOLT11インボイスを貼り付け (lnbc...)"
            aria-label="BOLT11 invoice input"></textarea>
          <div class="btn-row">
            <button class="tool-btn" id="btn-bolt11-decode" data-ko="디코드" data-en="Decode" data-ja="デコード">디코드</button>
            <button class="tool-btn sm" id="btn-bolt11-example" data-ko="예제 인보이스 로드" data-en="Load Example Invoice" data-ja="サンプルインボイスを読込">예제 인보이스 로드</button>
          </div>
          <div id="bolt11-result" class="tool-result"></div>
        </div>
      </section>

    </div>
  </main>


  <footer>
    <div class="footer-inner">
      <span>&copy; 2025 txid.uk — Bitcoin Explorer</span>
      <span data-ko="mempool.space API 사용" data-en="Powered by mempool.space API" data-ja="mempool.space API 使用">mempool.space API 사용</span>
    </div>
  </footer>

  <script>
    function escHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
    async function fetchRetry(url,timeout,retries){for(let i=0,m=retries||2;i<=m;i++){try{return await fetch(url,{signal:AbortSignal.timeout(timeout||10000)});}catch(e){if(i>=m)throw e;await new Promise(r=>setTimeout(r,1000<<i));}}}

    // ── 언어 ──
    let lang = localStorage.getItem('lang') || 'ko';
    const LABELS = {
      ko: {탐색기:'탐색기', 도구:'도구', 시각화:'시각화', 통계:'통계', 노드:'노드', 지도:'지도', 포트폴리오:'포트폴리오', 전송:'전송', 배우기:'배우기', 앱모음:'앱모음'},
      en: {탐색기:'Explorer', 도구:'Tools', 시각화:'Viz', 통계:'Stats', 노드:'Nodes', 지도:'Map', 포트폴리오:'Portfolio', 전송:'TX', 배우기:'Learn', 앱모음:'Apps'},
      ja: {탐색기:'探索', 도구:'ツール', 시각화:'可視化', 통계:'統計', 노드:'ノード', 지도:'地図', 포트폴리오:'資産', 전송:'送金', 배우기:'学習', 앱모음:'アプリ'},
    };

    // ── i18n 번역 ──
    const T = {
      ko: {
        invalid_addr: '❌ 유효하지 않은 주소 형식',
        valid_addr: '✓ 유효한 주소',
        invalid_hex: '유효한 hex를 입력하세요',
        type: '타입',
        network: '네트워크',
        length: '길이',
        length_chars: '자',
        view_explorer: '→ 탐색기에서 보기',
        data: '데이터',
        op_return_data: 'OP_RETURN (데이터)',
        unknown_script: '알 수 없는 스크립트',
        unknown: '알 수 없음',
        price_load_fail: '가격 로드 실패',
        retry: '재시도',
        bech32_error: 'bc1 또는 tb1로 시작하는 Bech32 주소가 아닙니다',
        base58_error: 'Base58 문자가 아닌 값이 포함돼 있습니다',
        invalid_raw_hex: '유효한 Raw TX hex를 입력하세요',
        confirm_broadcast: '이 트랜잭션을 비트코인 메인넷에 브로드캐스트하시겠습니까?\n\n한 번 전송하면 취소할 수 없습니다.',
        sending: '전송 중…',
        broadcast_ok: '✓ 브로드캐스트 성공!',
        error_prefix: '❌ 오류: ',
        network_error: '네트워크 오류가 발생했습니다. 잠시 후 다시 시도해주세요.',
        testnet_addr: 'Testnet 주소',
        p2pkh_mainnet: 'P2PKH 주소 (mainnet)',
        p2sh_mainnet: 'P2SH 주소 (mainnet)',
        p2pkh_testnet: 'P2PKH 주소 (testnet)',
        wif_privkey: 'WIF 개인키',
        no_search_result: '검색 결과 없음',
        light_mode: '라이트 모드로 전환',
        dark_mode: '다크 모드로 전환',
        // Script IDE
