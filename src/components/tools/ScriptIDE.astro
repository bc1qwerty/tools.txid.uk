    {name:'OP_8',aliases:['8'],cat:'const',desc:{ko:'8을 스택에 푸시',en:'Push 8',ja:'8をプッシュ'},hex:'0x58'},
    {name:'OP_9',aliases:['9'],cat:'const',desc:{ko:'9를 스택에 푸시',en:'Push 9',ja:'9をプッシュ'},hex:'0x59'},
    {name:'OP_10',aliases:['10'],cat:'const',desc:{ko:'10을 스택에 푸시',en:'Push 10',ja:'10をプッシュ'},hex:'0x5a'},
