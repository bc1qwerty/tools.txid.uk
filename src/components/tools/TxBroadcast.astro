<!-- TX Broadcast Tool -->
<section class="tool-card" id="tool-broadcast">
  <div class="tool-header">
    <svg class="tool-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    <h2 data-ko="TX 브로드캐스트" data-en="TX Broadcast" data-ja="TXブロードキャスト">TX 브로드캐스트</h2>
  </div>
  <div class="tool-body">
    <textarea id="tx-hex" class="tool-input textarea" placeholder="서명된 트랜잭션 hex 붙여넣기" data-ko="서명된 트랜잭션 hex 붙여넣기" data-en="Paste signed transaction hex" data-ja="署名済みトランザクションhexを貼り付け" aria-label="서명된 TX hex" spellcheck="false" rows="4"></textarea>
    <button class="tool-btn danger" id="btn-broadcast-tx" data-ko="네트워크에 전송" data-en="Broadcast to Network" data-ja="ネットワークに送信">네트워크에 전송</button>
    <div id="broadcast-result" class="tool-result"></div>
  </div>
</section>

<script is:inline>
(function() {
  var API = 'https://mempool.space/api';

  function broadcastTx() {
    var hex = document.getElementById('tx-hex').value.trim();
    if (!hex) return;
    if (!/^[0-9a-fA-F]+$/.test(hex) || hex.length < 20) { showResult('broadcast-result', '<span class="err">' + t('invalid_raw_hex') + '</span>', true); return; }
    if (!confirm(t('confirm_broadcast'))) return;
    showResult('broadcast-result', t('sending'));
    fetch(API + '/tx', { method: 'POST', body: hex, headers: { 'Content-Type': 'text/plain' }, signal: AbortSignal.timeout(15000) })
      .then(function(res) {
        return res.text().then(function(txid) {
          if (res.ok) {
            var isTxid=/^[0-9a-fA-F]{64}$/.test(txid.trim());
            var txLink=isTxid?'<a href="https://txid.uk/#/tx/'+txid.trim()+'" class="explorer-link" target="_blank">'+txid.trim()+'</a>':escHtml(txid.slice(0,200));
            showResult('broadcast-result', '<span class="ok">'+t('broadcast_ok')+'</span>\n' + row('TXID', txLink));
          } else {
            showResult('broadcast-result', '<span class="err">'+t('error_prefix')+escHtml(String(txid).slice(0,300))+'</span>', true);
          }
        });
      })
      .catch(function(e) { console.error('broadcastTx error:', e); showResult('broadcast-result', '<span class="err">'+t('network_error')+'</span>', true); });
  }

  document.getElementById('btn-broadcast-tx')?.addEventListener('click', broadcastTx);
})();
</script>
